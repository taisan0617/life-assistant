# ── Local development (.env.local) ────────────────────────────────────────────
# Copy this file to .env.local and fill in real values from `terraform output`.

VITE_CHAT_STREAM_URL=https://your-lambda-url.lambda-url.us-east-1.on.aws/
VITE_HISTORY_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/dev
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_REGION=us-east-1

# ── Production build (.env.production) ────────────────────────────────────────
# CloudFront serves /chat and /api/* as relative paths — see .env.production.
# Only Cognito vars need to be set there; copy them from terraform output.
